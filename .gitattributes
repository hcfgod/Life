#
# Git Attributes
# --------------
# Keep Unity-style `.meta` sidecar files consistent across platforms.
# This prevents CRLF/LF churn when contributors have different `core.autocrlf` settings.
#
*.meta text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.cpp text eol=lf
*.lua text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf

*.rar
*.7z

# Executables (platform specific)
*.exe
*.dll
*.so
*.dylib
*.app

# Debug symbols
*.pdb
*.dbg
*.sym

# Memory dumps
*.dmp
*.mdmp

# Crash reports
crash-reports/
*.crash 
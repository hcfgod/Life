.vscode/
.idea/
*.swp
*.swo
*~

# Logs
logs/
test_logs/

# Temporary files
temp/
tmp/
*.tmp
*.temp

# Configuration files (keep config.json but ignore local overrides)
config.local.json
config.dev.json
config.prod.json
imgui.ini

# Dependencies (if using package managers)

# NOTE: Do NOT ignore Unity-style `.meta` files.
# The asset system uses `.meta` as the stable GUID source-of-truth.
# Ignoring them guarantees GUID churn across machines and breaks GUID-based references.

# Premake generated files
*.workspace
Makefile
*.make

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
logs/
test_logs/

# Temporary files
temp/
tmp/
*.tmp
*.temp

# Configuration files (keep config.json but ignore local overrides)
config.local.json
config.dev.json
config.prod.json
imgui.ini

# Dependencies (if using package managers)
node_modules/
packages/

# Documentation build
docs/_build/
docs/build/

# Coverage reports
coverage/
*.gcov
*.gcda
*.gcno

# Profiling data
*.prof
*.gprof

# Core dumps
core
core.*
# Keep vendored msdfgen source directory tracked for CI builds.
!Limitless/Vendor/msdf-atlas-gen/msdfgen/core/
!Limitless/Vendor/msdf-atlas-gen/msdfgen/core/**

# Backup files
*.bak
*.backup
*.old

